# 작업 산출물 저장 디렉토리
STORAGE_DIR=./storage

# Demucs 모델 (htdemucs / htdemucs_ft / mdx_extra)
DEMUCS_MODEL=htdemucs

# 트랜스크립션 백엔드: basic_pitch | crepe
TRANSCRIBER=basic_pitch

# 베이스 튜닝: 4string | 5string
BASS_TUNING=5string

# Redis (arq 잡 큐)
REDIS_URL=redis://localhost:6379

# 입력 오디오 최대 길이 (초). 이보다 긴 영상/파일은 거절
MAX_DURATION_SEC=600
